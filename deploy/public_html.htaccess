<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Serve files from Laravel public (React build + API)
    RewriteCond %{DOCUMENT_ROOT}/../abrajtex/backend/public%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/../abrajtex/backend/public%{REQUEST_URI} -d
    RewriteRule ^(.*)$ ../abrajtex/backend/public/$1 [L]

    RewriteRule ^(.*)$ ../abrajtex/backend/public/$1 [L]
</IfModule>
